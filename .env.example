# Google AI API キー（https://aistudio.google.com/apikey）
GOOGLE_API_KEY=your_api_key_here

# デフォルト画像生成モデル
# Imagen: imagen-4.0-generate-001 / imagen-4.0-fast-generate-001
# Gemini: gemini-2.5-flash-image / gemini-3-pro-image-preview
GOOGLE_IMAGE_MODEL=imagen-4.0-generate-001
GOOGLE_EDIT_MODEL=gemini-2.5-flash-image
GOOGLE_PROMPT_MODEL=gemini-2.5-flash

# FastAPI サーバー
APP_HOST=0.0.0.0
APP_PORT=8000

# 公開 URL のベースパス（会社: /gazou、自宅は空のまま）
# APP_BASE_PATH=/gazou

# カスタマイズバックエンド: google | flux_local（Phase2・会社 GPU）
EDIT_BACKEND=google

# カスタムノードが参照する FastAPI 仲介 URL（未設定時は http://127.0.0.1:8000）
GOOGLE_AI_BRIDGE_URL=http://127.0.0.1:8000

# プロジェクトルート（未設定時はスクリプトが自動判定）
# GOOGLE_AI_PROJECT_ROOT=/path/to/comfy-google-ai

# ComfyUI サーバー（CPU モードで起動）
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# 生成画像の保存先
OUTPUT_DIR=./output
