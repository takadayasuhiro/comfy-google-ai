# 会社 AI サーバー向け環境変数テンプレ（2026/06/07）
# cp .env.company.example .env && nano .env

# --- Google AI API ---
GOOGLE_API_KEY=your_api_key_here
GOOGLE_IMAGE_MODEL=imagen-4.0-generate-001
GOOGLE_EDIT_MODEL=gemini-2.5-flash-image
GOOGLE_PROMPT_MODEL=gemini-2.5-flash

# --- 公開 URL（nginx サブパス）---
# 社員は http://localhost/gazou でアクセス（ポート番号不要）
APP_BASE_PATH=/gazou

# --- FastAPI（内部。nginx が /gazou/ から転送）---
APP_HOST=0.0.0.0
APP_PORT=8000
GOOGLE_AI_BRIDGE_URL=http://127.0.0.1:8000

# --- ComfyUI（社員非公開・localhost のみ）---
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# --- カスタマイズバックエンド（Phase2）---
# Phase1: google（Gemini 編集 API）
# Phase2: flux_local（FLUX.1 Schnell img2img、GPU 要）
EDIT_BACKEND=google

# Phase2 で GPU 起動する場合:
# COMFYUI_GPU=1
# FLUX_MODEL=flux1-schnell-Q4_K_S.gguf
# FLUX_DENOISE=0.45

OUTPUT_DIR=./output
